# Copy this file to .env and fill in real values. .env is gitignored.
# These same variable names are used locally AND as Railway env vars.

# --- Engine API keys (server-only) ---
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...
PERPLEXITY_API_KEY=pplx-...
# ANTHROPIC_API_KEY=sk-ant-...        # reserved, not used yet

# --- Supabase (runtime persistence; service-role is SERVER-ONLY) ---
# Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # service_role secret — NEVER expose to the frontend

# --- Direct Postgres connection (migrations only) ---
# Project Settings → Database → Connection string → Session pooler (port 5432).
# Replace [YOUR-PASSWORD] with your real DB password.
DATABASE_URL=postgresql://postgres.YOUR-REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- Spend / runtime config ---
DAILY_SPEND_CAP_USD=10
NODE_ENV=development                  # Railway: set to production
# DATA_DIR=/data                      # Railway: the attached volume mount path
# PORT=8787                           # Railway sets this automatically
# FREE_SCANS_PER_EMAIL=2
# FREE_SCANS_PER_IP=2

# --- Durable job queue (Phase 1) ---
# Process role per Railway service. One image, three services. See LAUNCH_CHECKLIST.md.
#   web (default): npm run migrate; npm start    PROCESS_MODE=web
#   worker:        npm run worker                PROCESS_MODE=worker
#   scheduler:     npm run scheduler             PROCESS_MODE=scheduler
# PROCESS_MODE=web
# JOB_QUEUE_ENABLED=0                 # 1 = route scans through the durable queue (after a worker exists + verified)
# WORKER_IN_PROCESS=0                 # 1 = web process also runs the worker loop (dev/single-service)
# QUEUE_GLOBAL_CONCURRENCY=4          # max jobs running across all workers
# QUEUE_SHOP_CONCURRENCY=1            # max concurrent jobs per shop
# QUEUE_EMAIL_CONCURRENCY=1           # max concurrent jobs per email
# QUEUE_LEASE_SEC=120                 # job lease; exceeded => abandoned-job recovery requeues it
# QUEUE_POLL_MS=2000
# QUEUE_RECOVER_GRACE_SEC=30
# PG_POOL_MAX=8                       # runtime pg pool size (queue uses raw pg for row locks)

# --- Admin cockpit (/admin) ---
ADMIN_PASSWORD=change-me-strong       # required to access /admin; unset = admin disabled
IP_HASH_SALT=set-a-random-string      # salts the one-way IP hash stored for abuse limits

# --- Public branding (NEVER put "Shopify" here — trademark) ---
PUBLIC_BRAND_NAME=AI Visibility       # the public name shown in UI/titles/OG/emails
PUBLIC_BASE_URL=                      # absolute URL behind a custom domain, e.g. https://yourbrand.com (blank = derive from request)
CONTACT_EMAIL=                        # shown on privacy page + footer

# --- Stripe Payment Links (URLs only; missing => email-capture modal fallback) ---
# Tip: in the Stripe dashboard, add metadata `plan=full_report` (etc.) to each
# Payment Link so the webhook can label the order without guessing from the amount.
STRIPE_FULL_REPORT_URL=
STRIPE_WEEKLY_MONITORING_URL=       # blank => "Coming soon" / beta waitlist in the UI
STRIPE_FOUNDER_BETA_URL=

# --- Shopify public app (Phase 2) ---
# SHOPIFY_MODE=mock lets the full OAuth/webhook flow run + be tested with NO real
# Shopify credentials (only APP_ENCRYPTION_KEY is needed). Set to 'live' with real
# key/secret to connect actual stores. See LAUNCH_CHECKLIST.md for Partner-app setup.
# SHOPIFY_MODE=mock
SHOPIFY_API_KEY=                      # Partner dashboard → app → API key
SHOPIFY_API_SECRET=                   # Partner dashboard → app → API secret (rotate the exposed one!)
SHOPIFY_SCOPES=read_products          # least privilege; add write_products only for approved writes
SHOPIFY_API_VERSION=2025-01           # current stable GraphQL Admin API version
SHOPIFY_APP_URL=                      # public https base for OAuth callback + webhooks (e.g. https://lens.thirdocular.com)
# Token encryption at rest (AES-256-GCM). Generate once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=                   # base64, 32 bytes. Losing it => all shops must reconnect.

# --- Stripe webhook (proof of payment) ---
# Webhook endpoint: POST /api/stripe/webhook  (event: checkout.session.completed)
STRIPE_WEBHOOK_SECRET=              # whsec_... — signing secret; required to accept webhooks
STRIPE_SECRET_KEY=                  # sk_... — optional; if set, the webhook re-confirms paid via the API

# --- Evidence & diagnosis crawler (Phase 5) ---
# The crawler explains WHY competitors win by fetching the merchant's page + the
# competitor pages the AI engines cited, then diagnosing the structural gap.
# CRAWLER_MODE=mock (default) runs the FULL pipeline against built-in fixtures at
# $0 with NO network. 'live' makes outbound HTTP requests (spends no API money, but
# is gated for the network access). SSRF + prompt-injection are the primary threat
# model — private/link-local/metadata IPs are blocked and all crawled text is
# treated as untrusted. Limits below are hard caps per crawl.
# CRAWLER_MODE=mock
CRAWLER_MAX_PAGES=8                 # hard cap on pages fetched per diagnosis
CRAWLER_MAX_DEPTH=1                 # same-origin link-follow depth (0 = seeds only)
CRAWLER_MAX_BYTES=2500000          # per-page body byte cap (socket destroyed beyond)
CRAWLER_TIMEOUT_MS=10000           # per-request timeout
CRAWLER_MAX_REDIRECTS=4            # each redirect hop is re-validated through the SSRF guard
CRAWLER_RESPECT_ROBOTS=1           # 0 to ignore robots.txt (not recommended)
