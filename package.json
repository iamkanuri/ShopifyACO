{
  "name": "shopify-aco",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ShopifyACO — AI-visibility measurement engine: does ChatGPT/Gemini/Perplexity recommend your store vs competitors?",
  "scripts": {
    "scan": "tsx src/index.ts",
    "analyze": "tsx src/analyze.ts",
    "server": "tsx src/server/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "build": "npm --prefix viewer install --include=dev && npm --prefix viewer run build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
